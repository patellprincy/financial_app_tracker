# ============================================================
#  MAIN BACKEND SERVICE  —  port 8000
#  Copy this file to .env and fill in your values.
#  Run: uvicorn app.main:app --reload --port 8000
# ============================================================

DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname
JWT_SECRET_KEY=your-jwt-secret-key-here-minimum-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
APP_ENV=development

# URL of the AI classification microservice.
# Local development (AI service on port 8001):
AI_BACKEND_URL=http://localhost:8001
# Production example:
# AI_BACKEND_URL=https://ai.your-domain.com
