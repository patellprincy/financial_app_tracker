# ============================================================
#  AI MICROSERVICE  —  port 8001
#  Copy this file to .env and fill in your values.
#  Run: uvicorn ai.app:app --reload --host 0.0.0.0 --port 8001
# ============================================================

# Required: Groq API key — get one at https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# Groq model to use for classification and statement cleanup
GROQ_MODEL=llama-3.1-8b-instant

# Service metadata (optional)
AI_SERVICE_NAME=finsight-ai-service
AI_ENV=development
